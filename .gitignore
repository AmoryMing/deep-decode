# 历史备份
*.bak
*.bak.*

# 大体积二进制（agent 不需要，自己跑出来即可）
*.docx
*.mp3
*.wav
*.mp4
*.png
*.jpg
*.jpeg

# 但 demo 目录里的代表作二进制保留 — 让别人能看到完整四件套效果
!examples/2026-04-09-managed-agents-architecture/*.svg
!examples/2026-04-09-managed-agents-architecture/*.docx

# Skill 运行时状态
state/
.omc/
graphify-runs/

# graphify 中间产物（agent 自己跑生成即可，太大不入仓）
graphify-out/cache/
graphify-out/converted/
graphify-out/graph.json
graphify-out/graph.html

# 依赖
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# 编辑器
.DS_Store
.vscode/
.idea/
*.swp

# 临时
*.log
*.tmp
.cache/
